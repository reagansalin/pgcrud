<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h1 class="h3 mb-4"><%= formTitle %></h1>
        <form action="<%= action %>" method="POST">
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" id="title" name="title" class="form-control" value="<%= book.title %>" required>
          </div>

          <div class="mb-3">
            <label for="author" class="form-label">Author</label>
            <input type="text" id="author" name="author" class="form-control" value="<%= book.author %>" required>
          </div>

          <div class="mb-3">
            <label for="comments" class="form-label">Comments</label>
            <textarea id="comments" name="comments" class="form-control" rows="4"><%= book.comments %></textarea>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
            <a href="/books" class="btn btn-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
